{
    "name": "Python TPC-H Development",
    "dockerFile": "../Dockerfile",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },
    "forwardPorts": [8888],
    "postCreateCommand": "pip install jupyter notebook",
    "remoteUser": "root"
} 